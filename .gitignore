.idea/
.vscode/*
!.vscode/settings.json
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff cache
.ruff_cache/

# Docker (compose override files with local secrets)
docker-compose.override.yml
docker-compose.local.yml
